# ============================================================
# Variáveis de ambiente — copie para .env e ajuste
#   cp .env.example .env
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=movies
POSTGRES_PASSWORD=movies
POSTGRES_DB=movies
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# String de conexão usada pelo backend (host = nome do serviço no compose)
DATABASE_URL=postgresql+psycopg://movies:movies@postgres:5432/movies

# ---- Qdrant (banco vetorial) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# ---- ML Service (TensorFlow.js) ----
ML_SERVICE_URL=http://ml-service:3001

# ---- Backend ----
BACKEND_PORT=8000
ENVIRONMENT=development

# ---- Frontend ----
# URL do backend vista pelo browser (host, não rede docker)
VITE_API_URL=http://localhost:8000
